<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Preview Kamera (fullscreen) -->

    <!-- Tombol Back (kiri atas) -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0" />

    <ImageButton
        android:id="@+id/btn_back"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="#66000000"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@android:color/white"
        android:contentDescription="Kembali"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_margin="16dp"/>

    <!-- Tombol Flip Kamera (kanan atas) -->
    <ImageButton
        android:id="@+id/btn_flip_camera"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="#66000000"
        android:src="@drawable/ic_camera_flip"
        android:contentDescription="Balik Kamera"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_margin="16dp"/>

    <!-- Overlay GPS Info (bawah, di atas tombol capture) -->
    <LinearLayout
        android:id="@+id/layout_gps_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        app:layout_constraintBottom_toTopOf="@id/layout_capture_bar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Koordinat -->
        <TextView
            android:id="@+id/tv_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📍 Mendapatkan lokasi..."
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp"/>

        <!-- Tanggal & Waktu -->
        <TextView
            android:id="@+id/tv_date_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 --"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="2dp"/>

        <!-- Alamat -->
        <TextView
            android:id="@+id/tv_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🏠 Mencari alamat..."
            android:textColor="#00E5FF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:maxLines="2"
            android:ellipsize="end"/>

    </LinearLayout>

    <!-- Bar bawah: tombol capture -->
    <LinearLayout
        android:id="@+id/layout_capture_bar"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="#CC000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Tombol Capture -->
        <ImageButton
            android:id="@+id/btn_capture"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/bg_capture_button"
            android:src="@android:drawable/ic_menu_camera"
            android:tint="@android:color/white"
            android:padding="16dp"
            android:contentDescription="Ambil Foto"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>