<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:layout_marginTop="12dp">

    <!-- Card utama -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card_white_rounded"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:layout_marginTop="10dp">

        <!-- Kiri: Nama SPBU + Sopir + Jenis Produk + Waktu -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_nomor_spbu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SPBU 562114"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_nama_sopir"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sopir: -"
                android:textColor="@color/text_h"
                android:textSize="12sp"
                android:layout_marginTop="4dp" />

            <TextView
                android:id="@+id/tv_jenis_produk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pertamax Turbo"
                android:textColor="@color/text_h"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_completed_at"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selesai: -"
                android:textColor="@color/text_h"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Kanan: Nomor LO + Jumlah KL -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_nomor_lo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="214525884"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="end" />

            <TextView
                android:id="@+id/tv_jumlah_kl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1800 L"
                android:textColor="@color/text_h"
                android:textSize="12sp"
                android:gravity="end" />

        </LinearLayout>
    </LinearLayout>

    <!-- Badge "Selesai" overlap di pojok kanan atas -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_marginEnd="20dp"
        android:text="Selesai"
        android:textColor="@color/white"
        android:textSize="11sp"
        android:textStyle="bold"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_status_green_rounded" />

</FrameLayout>